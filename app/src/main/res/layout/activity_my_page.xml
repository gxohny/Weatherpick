<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/coordinator"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".MyPageActivity">


    <LinearLayout
        android:id="@+id/layout_mypage_content"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">


        <ImageView
            android:id="@+id/img_user"
            android:layout_width="40dp"
            android:layout_height="32dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="32dp"
            android:contentDescription="@string/app_name"
            android:src="@drawable/logo1" />


        <TextView
            android:id="@+id/tv_saved_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="100dp"
            android:text="저장한 문구"
            android:textSize="18sp"
            android:textStyle="bold" />


        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layout_saved_card"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginTop="30dp"
            android:background="@drawable/bg_saved_card">


            <ImageView
                android:id="@+id/btn_prev"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_left"
                android:contentDescription="이전 문구"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:layout_marginStart="16dp" />


            <ImageView
                android:id="@+id/btn_next"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_right"
                android:contentDescription="다음 문구"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:layout_marginEnd="16dp" />


            <ImageView
                android:id="@+id/img_saved_weather"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_cloud_blue"
                app:layout_constraintTop_toTopOf="parent"
                android:layout_marginTop="24dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />


            <TextView
                android:id="@+id/tv_saved_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="25.11.10"
                android:textSize="12sp"
                app:layout_constraintTop_toBottomOf="@id/img_saved_weather"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="8dp" />


            <TextView
                android:id="@+id/tv_saved_sentence"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginStart="32dp"
                android:layout_marginEnd="32dp"
                android:text="햇살은 맑지만 바람이 차가워요.\n외투 챙기는 거 잊지 마세요!"
                android:textSize="14sp"
                android:textColor="#333333"
                android:gravity="center"
                app:layout_constraintTop_toBottomOf="@id/tv_saved_date"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>


        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

    </LinearLayout>


    <LinearLayout
        android:id="@+id/layout_logo_area"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:gravity="center"
        android:background="@android:color/white">


        <ImageView
            android:id="@+id/img_logo"
            android:layout_width="500dp"
            android:layout_height="100dp"
            android:src="@drawable/logo1"
            android:adjustViewBounds="true"
            android:scaleType="fitCenter"
            android:contentDescription="@string/app_name" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/bottomSheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
        app:behavior_peekHeight="60dp"
        app:behavior_hideable="false">

        <edu.sungshin.weatherpick.WeatherBottomSheetView
            android:id="@+id/weatherBottomSheet"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
